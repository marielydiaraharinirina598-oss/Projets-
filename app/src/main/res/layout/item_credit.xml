<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="14dp"
    android:layout_marginLeft="8dp"
    android:layout_marginRight="8dp"
    android:layout_marginBottom="8dp"
    android:elevation="2dp">

    <!-- Ligne 1 : Montant + Statut -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvMontant"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 Ar"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"/>

        <TextView
            android:id="@+id/tvStatut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"/>
    </LinearLayout>

    <!-- Ligne 2 : Taux et durée -->
    <TextView
        android:id="@+id/tvTaux"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Taux : -"
        android:textSize="13sp"
        android:textColor="#555555"
        android:layout_marginBottom="2dp"/>

    <!-- Ligne 3 : Fréquence -->
    <TextView
        android:id="@+id/tvFrequence"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="-"
        android:textSize="13sp"
        android:textColor="#555555"
        android:layout_marginBottom="2dp"/>

    <!-- Ligne 4 : Mensualité -->
    <TextView
        android:id="@+id/tvMensualite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mensualité : -"
        android:textSize="13sp"
        android:textColor="#1565C0"
        android:layout_marginBottom="2dp"/>

    <!-- Ligne 5 : Restant dû -->
    <TextView
        android:id="@+id/tvRestant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Restant : -"
        android:textSize="13sp"
        android:textColor="#E65100"
        android:layout_marginBottom="2dp"/>

    <!-- Ligne 6 : Date -->
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Début : -"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="10dp"/>

    <!-- Boutons actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btnEcheancier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 Échéancier"
            android:textSize="13sp"
            android:textColor="#2E7D32"
            android:padding="8dp"
            android:layout_marginRight="8dp"/>

        <TextView
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑 Supprimer"
            android:textSize="13sp"
            android:textColor="#C62828"
            android:padding="8dp"/>
    </LinearLayout>

</LinearLayout>