<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header rouge -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#C62828" android:padding="16dp"
        android:orientation="horizontal" android:gravity="center_vertical">
        <Button android:id="@+id/btnRetour" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="←" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#FFFFFF"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="⚠️ Paiements en Retard"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvCountRetard" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="0 retard(s)"
            android:textColor="#FFCDD2" android:textSize="12sp"/>
    </LinearLayout>

    <!-- Total en retard -->
    <TextView android:id="@+id/tvTotalRetard"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FFEBEE" android:padding="14dp"
        android:text="Montant total en retard : 0 Ar"
        android:textColor="#C62828" android:textStyle="bold" android:textSize="14sp"/>

    <!-- Message si vide -->
    <TextView android:id="@+id/tvVide"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="✅ Aucun retard de paiement !"
        android:textSize="16sp" android:gravity="center"
        android:textColor="#2E7D32" android:padding="32dp"
        android:visibility="gone"/>

    <!-- Liste retards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRetards"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>